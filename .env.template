# .env.template
# ===== ОСНОВНЫЕ НАСТРОЙКИ =====
SECRET_KEY=сгенерируйте-случайную-строку

# ===== РЕЖИМ АУТЕНТИФИКАЦИИ =====
# local - для разработки (admin/admin)
# ldap - для продакшена (Active Directory)
AUTH_MODE=ldap

# ===== НАСТРОЙКИ AD (только если AUTH_MODE=ldap) =====
LDAP_SERVER=
LDAP_DOMAIN=
LDAP_BASE_DN=
LDAP_BIND_USER=
LDAP_BIND_PASSWORD=

# ===== МАППИНГ ГРУПП AD НА РОЛИ =====
AD_GROUP_ADMIN=
AD_GROUP_OPERATOR=
AD_GROUP_VIEWER=

# ===== НАСТРОЙКИ ПОДКЛЮЧЕНИЯ К ОБОРУДОВАНИЮ =====
DEVICE_USERNAME=admin
DEVICE_PASSWORD=DefHccb01
DEVICE_ENABLE=

# Database
DATABASE_URL=sqlite:///devices.db
# Для PostgreSQL раскомментировать:
# DATABASE_URL=postgresql://kontrollka:password@localhost:5432/kontrollka