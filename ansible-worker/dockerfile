FROM python:3.13

RUN apt-get update && apt-get install -y \
    ansible \
    openssh-client \
    openssh-server \
    && rm -rf /var/lib/apt/lists/*

# Устанавливаем все популярные коллекции
RUN ansible-galaxy collection install \
    ansible.netcommon \
    huawei.cloudengine \
    cisco.ios \
    cisco.nxos \
    junipernetworks.junos \
    arista.eos \
    fortinet.fortios

WORKDIR /app

RUN pip install --no-cache-dir redis pyyaml ansible-pylibssh

COPY worker.py .

CMD ["python", "worker.py"]